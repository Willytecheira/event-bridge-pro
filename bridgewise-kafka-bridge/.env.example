# ===== Bridgewise External Kafka =====
BRIDGEWISE_KAFKA_BROKERS=your-broker:9093
BRIDGEWISE_KAFKA_USERNAME=your-username
BRIDGEWISE_KAFKA_PASSWORD=your-password
BRIDGEWISE_KAFKA_MECHANISM=scram-sha-512
BRIDGEWISE_CONSUMER_GROUP=bridgewise-bridge-consumer
BRIDGEWISE_TOPIC=alerts-reasoning-external

# ===== Internal Kafka =====
INTERNAL_KAFKA_BROKERS=localhost:9092
INTERNAL_KAFKA_CLIENT_ID=bridgewise-bridge
INTERNAL_TOPIC_RAW=bridgewise.alerts.raw
INTERNAL_TOPIC_NORMALIZED=bridgewise.alerts.normalized
INTERNAL_TOPIC_ERRORS=bridgewise.alerts.errors

# ===== Supabase / Lovable Cloud Database =====
SUPABASE_URL=https://qsmlkzqlrjlvbjqgkvmk.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===== Processing =====
BYTES_TO_STRIP=5

# ===== Worker =====
NODE_ENV=production
LOG_LEVEL=info
