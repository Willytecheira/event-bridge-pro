# ===== Bridgewise External Kafka (Confluent Cloud) =====
BRIDGEWISE_KAFKA_BROKERS=pkc-xxxxx.us-east-1.aws.confluent.cloud:9092
BRIDGEWISE_KAFKA_USERNAME=your-api-key
BRIDGEWISE_KAFKA_PASSWORD=your-api-secret
BRIDGEWISE_KAFKA_MECHANISM=plain
BRIDGEWISE_CONSUMER_GROUP=your-consumer-group
BRIDGEWISE_TOPIC=your-topic-name

# ===== Internal Kafka =====
INTERNAL_KAFKA_BROKERS=localhost:9092
INTERNAL_KAFKA_CLIENT_ID=bridgewise-bridge
INTERNAL_TOPIC_RAW=bridgewise.alerts.raw
INTERNAL_TOPIC_NORMALIZED=bridgewise.alerts.normalized
INTERNAL_TOPIC_ERRORS=bridgewise.alerts.errors

# ===== Supabase / Lovable Cloud Database =====
SUPABASE_URL=https://qsmlkzqlrjlvbjqgkvmk.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===== Processing =====
BYTES_TO_STRIP=5

# ===== Worker =====
NODE_ENV=production
LOG_LEVEL=info
